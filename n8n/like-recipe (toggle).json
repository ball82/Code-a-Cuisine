    {
      "parameters": {
        "jsCode": "// Body aus dem Webhook holen\nconst body = $json.body ?? {};\nconst errors = [];\n\nconst recipeId = body.recipeId;\nconst userId = body.userId;\n\n// Firestore-Auto-IDs = 20 Zeichen alphanumerisch.\n// Die Regex schliesst \"/\" und \"..\" aus -> keine Path-Injection moeglich.\nif (typeof recipeId !== 'string' || !/^[A-Za-z0-9]{20}$/.test(recipeId)) {\n  errors.push('recipeId fehlt oder hat ungueltiges Format');\n}\n\n// userId kommt vom Client (z.B. crypto.randomUUID() im localStorage).\n// Gleiche Absicherung: nur unbedenkliche Zeichen erlauben.\nif (typeof userId !== 'string' || !/^[A-Za-z0-9_-]{8,64}$/.test(userId)) {\n  errors.push('userId fehlt oder hat ungueltiges Format');\n}\n\nif (errors.length) {\n  return [{ json: { valid: false, errors } }];\n}\nreturn [{ json: { valid: true, recipeId, userId } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
