    {
      "parameters": {
        "jsCode": "const { recipeId, userId } = $('Like validieren').first().json;\n\nconst base = 'projects/code-a-cuisine-9c87f/databases/(default)/documents';\nconst likeDoc = `${base}/recipes/${recipeId}/likes/${userId}`;\nconst recipeDoc = `${base}/recipes/${recipeId}`;\n\n// 200 = Like-Dokument existiert bereits -> Unlike\n// 404 = noch kein Like -> Like setzen\nconst alreadyLiked = $json.statusCode === 200;\nconst delta = alreadyLiked ? '-1' : '1';\n\n// Zaehler auf dem Rezept atomar aendern\nconst counterWrite = {\n  update: { name: recipeDoc, fields: {} },\n  updateMask: { fieldPaths: [] },            // leere Maske = kein Feld ueberschreiben\n  updateTransforms: [{\n    fieldPath: 'likes',\n    increment: { integerValue: delta }\n  }],\n  currentDocument: { exists: true }          // nur wenn das Rezept existiert\n};\n\n// Like-Dokument anlegen bzw. loeschen.\n// Die Preconditions verhindern doppeltes Zaehlen bei Doppelklick/Race.\nconst likeWrite = alreadyLiked\n  ? {\n      delete: likeDoc,\n      currentDocument: { exists: true }\n    }\n  : {\n      update: {\n        name: likeDoc,\n        fields: { createdAt: { timestampValue: new Date().toISOString() } }\n      },\n      currentDocument: { exists: false }\n    };\n\n// Beide Writes in EINEM Commit = atomar (beides oder nichts)\nreturn [{\n  json: {\n    recipeId,\n    userId,\n    liked: !alreadyLiked,\n    writes: [likeWrite, counterWrite]\n  }\n}];"
      },
